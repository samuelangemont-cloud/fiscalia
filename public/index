<script>
// ── TAX CALCULATION (barème 2024 sur revenus 2024) ──────────────────────────
function calcImpot(revenuNet, parts) {
  const rqf = revenuNet / parts;
  let impot = 0;
  // Tranches 2024
  const tranches = [
    { max: 11294,  taux: 0 },
    { max: 28797,  taux: 0.11 },
    { max: 82341,  taux: 0.30 },
    { max: 177106, taux: 0.41 },
    { max: Infinity, taux: 0.45 },
  ];
  let prev = 0;
  for (const t of tranches) {
    if (rqf <= prev) break;
    const base = Math.min(rqf, t.max) - prev;
    impot += base * t.taux;
    prev = t.max;
  }
  return Math.max(0, impot * parts);
}

function fmt(n) { return n.toLocaleString('fr-FR', { maximumFractionDigits: 0 }) + ' €'; }

function updateTaxPreview() {
  const salaires  = parseFloat(document.getElementById('pdf_salaires').value) || 0;
  const autres    = parseFloat(document.getElementById('pdf_autres').value)   || 0;
  const charges   = parseFloat(document.getElementById('pdf_charges').value)  || 0;
  const reductions= parseFloat(document.getElementById('pdf_reductions').value)||0;
  const parts     = parseFloat(document.getElementById('pdf_parts').value)    || 1;

  const brut   = salaires + autres;
  const abatt  = Math.min(Math.max(salaires * 0.10, 495), 14171);
  const net    = Math.max(0, brut - abatt - charges);
  const brutImp= calcImpot(net, parts);
  const final  = Math.max(0, brutImp - reductions);

  document.getElementById('prev_brut').textContent     = fmt(brut);
  document.getElementById('prev_abatt').textContent    = '− ' + fmt(abatt);
  document.getElementById('prev_net').textContent      = fmt(net);
  document.getElementById('prev_brut_imp').textContent = fmt(brutImp);
  document.getElementById('prev_red').textContent      = '− ' + fmt(reductions);
  document.getElementById('prev_final').textContent    = fmt(final);

  return { brut, abatt, net, brutImp, reductions, final, parts };
}

// ── MODAL ────────────────────────────────────────────────────────────────────
function openExportModal() {
  document.getElementById('exportModal').classList.add('open');
  updateTaxPreview();
}
function closeExportModal() {
  document.getElementById('exportModal').classList.remove('open');
}
document.getElementById('exportModal').addEventListener('click', function(e) {
  if (e.target === this) closeExportModal();
});

// ── PDF GENERATION ───────────────────────────────────────────────────────────
function generatePDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ unit: 'mm', format: 'a4' });

  const nom       = document.getElementById('pdf_nom').value      || 'Non renseigné';
  const prenom    = document.getElementById('pdf_prenom').value   || 'Non renseigné';
  const spi       = document.getElementById('pdf_spi').value      || '—';
  const situation = document.getElementById('pdf_situation').value;
  const parts     = document.getElementById('pdf_parts').value;
  const salaires  = parseFloat(document.getElementById('pdf_salaires').value) || 0;
  const autres    = parseFloat(document.getElementById('pdf_autres').value)   || 0;
  const charges   = parseFloat(document.getElementById('pdf_charges').value)  || 0;
  const reductions= parseFloat(document.getElementById('pdf_reductions').value)||0;
  const tax       = updateTaxPreview();

  const W = 210; // page width mm
  const M = 18;  // margin
  let y   = 0;

  // ── PAGE BACKGROUND ──
  doc.setFillColor(13, 27, 42);
  doc.rect(0, 0, W, 297, 'F');

  // ── HEADER BAND ──
  doc.setFillColor(201, 168, 76);
  doc.rect(0, 0, W, 42, 'F');

  // Logo
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(26);
  doc.setTextColor(13, 27, 42);
  doc.text('FiscalIA', M, 20);

  doc.setFont('helvetica', 'normal');
  doc.setFontSize(9);
  doc.setTextColor(13, 27, 42, 0.7);
  doc.text('Déclaration de revenus 2025 — Revenus 2024', M, 28);
  doc.text('Document préparé le ' + new Date().toLocaleDateString('fr-FR'), M, 35);

  // Document title right-aligned
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(10);
  doc.setTextColor(13, 27, 42);
  doc.text('RÉCAPITULATIF FISCAL', W - M, 22, { align: 'right' });
  doc.setFont('helvetica', 'normal');
  doc.setFontSize(8);
  doc.text('Formulaire 2042 — Aide à la déclaration', W - M, 30, { align: 'right' });

  y = 54;

  // ── SECTION helper ──
  function section(title) {
    doc.setFillColor(30, 58, 95);
    doc.roundedRect(M, y, W - 2*M, 9, 2, 2, 'F');
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(9);
    doc.setTextColor(201, 168, 76);
    doc.text(title.toUpperCase(), M + 4, y + 6);
    y += 14;
  }

  // ── ROW helper ──
  function row(label, value, highlight=false) {
    doc.setDrawColor(255, 255, 255, 0.08);
    doc.setLineWidth(0.2);
    doc.line(M, y, W - M, y);

    doc.setFont('helvetica', 'normal');
    doc.setFontSize(9);
    doc.setTextColor(213, 208, 196);
    doc.text(label, M + 3, y + 6);

    doc.setFont('helvetica', highlight ? 'bold' : 'normal');
    doc.setTextColor(highlight ? 111 : 201, highlight ? 207 : 168, highlight ? 151 : 76);
    doc.text(value, W - M - 3, y + 6, { align: 'right' });
    y += 9;
  }

  function spacer(h=5) { y += h; }

  // ── IDENTITÉ ──
  section('Identification du contribuable');
  row('Nom et Prénom', prenom + ' ' + nom.toUpperCase());
  row('Numéro fiscal (SPI)', spi);
  row('Situation familiale', situation);
  row('Quotient familial', parts + ' part(s)');
  spacer();

  // ── REVENUS ──
  section('Revenus déclarés');
  row('Salaires, traitements nets (cases 1AJ/1BJ)', salaires.toLocaleString('fr-FR') + ' €');
  row('Autres revenus', autres.toLocaleString('fr-FR') + ' €');
  row('Revenu brut global', tax.brut.toLocaleString('fr-FR') + ' €');
  spacer();

  // ── DÉDUCTIONS ──
  section('Déductions et charges');
  row('Abattement 10% sur salaires (plafonné)', '− ' + tax.abatt.toLocaleString('fr-FR') + ' €');
  row('Charges déductibles', '− ' + charges.toLocaleString('fr-FR') + ' €');
  row('Revenu net imposable', tax.net.toLocaleString('fr-FR') + ' €');
  spacer();

  // ── CALCUL ──
  section('Calcul de l\'impôt (barème progressif 2024)');
  row('Impôt brut avant réductions', tax.brutImp.toLocaleString('fr-FR') + ' €');
  row('Réductions et crédits d\'impôt', '− ' + reductions.toLocaleString('fr-FR') + ' €');
  spacer(3);

  // Final tax box
  doc.setFillColor(201, 168, 76, 0.15);
  doc.setDrawColor(201, 168, 76);
  doc.setLineWidth(0.5);
  doc.roundedRect(M, y, W - 2*M, 14, 3, 3);
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(10);
  doc.setTextColor(201, 168, 76);
  doc.text('IMPÔT ESTIMÉ À PAYER', M + 5, y + 9);
  doc.setFontSize(13);
  doc.setTextColor(111, 207, 151);
  doc.text(tax.final.toLocaleString('fr-FR') + ' €', W - M - 5, y + 9, { align: 'right' });
  y += 22;

  // ── CONVERSATION SUMMARY ──
  spacer(3);
  section('Résumé de la conversation avec Léa (IA)');

  const msgs = messages.filter(m => m.role === 'assistant').slice(-5);
  doc.setFont('helvetica', 'normal');
  doc.setFontSize(8);
  doc.setTextColor(180, 175, 165);

  msgs.forEach(m => {
    const clean = m.content.replace(/\*\*/g, '').replace(/\n+/g, ' ').substring(0, 180);
    const lines = doc.splitTextToSize('• ' + clean + (m.content.length > 180 ? '…' : ''), W - 2*M - 6);
    if (y + lines.length * 5 > 270) return; // avoid overflow
    doc.text(lines, M + 3, y);
    y += lines.length * 5 + 2;
  });

  spacer(6);

  // ── FOOTER ──
  doc.setFillColor(201, 168, 76);
  doc.rect(0, 282, W, 15, 'F');
  doc.setFont('helvetica', 'normal');
  doc.setFontSize(7.5);
  doc.setTextColor(13, 27, 42);
  doc.text('⚠ Ce document est une aide à la préparation de votre déclaration. Il ne constitue pas un avis fiscal officiel.', W/2, 289, { align: 'center' });
  doc.text('Pour valider votre déclaration, rendez-vous sur impots.gouv.fr avant le 22 mai 2026.', W/2, 294, { align: 'center' });

  // Download
  const filename = `FiscalIA_${nom}_${prenom}_2024.pdf`.replace(/\s+/g, '_');
  doc.save(filename);
  closeExportModal();
}
</script>


